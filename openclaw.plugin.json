{
  "id": "skill-usage-audit",
  "name": "Skill Usage Audit",
  "description": "Writes tool and skill usage telemetry to SQLite for audit and self-improving skill lifecycle.",
  "version": "1.0.0",
  "entry": "index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": {
        "type": "string",
        "description": "SQLite database path for canonical telemetry. Defaults to ~/.openclaw/audits/skill-usage.db",
        "default": "~/.openclaw/audits/skill-usage.db"
      },
      "includeToolParams": {
        "type": "boolean",
        "description": "Whether to include tool params in tool_call_start/end events",
        "default": false
      },
      "captureMessageContent": {
        "type": "boolean",
        "description": "When true, store message text snapshots; when false, store only metadata + labels for privacy",
        "default": false
      },
      "redactKeys": {
        "type": "array",
        "description": "List of param keys to redact in tool event payloads",
        "items": {
          "type": "string"
        },
        "default": [
          "token",
          "apikey",
          "api_key",
          "apiKey",
          "password",
          "passwd",
          "auth",
          "authorization",
          "secret",
          "secretToken",
          "refreshToken",
          "client_secret"
        ]
      },
      "skillBlockDetection": {
        "type": "boolean",
        "description": "Whether to emit skill_block_detected events from before_prompt_build",
        "default": true
      },
      "contextWindowSize": {
        "type": "integer",
        "description": "Number of messages to retain before/after a skill read for execution context capture",
        "minimum": 1,
        "default": 5
      },
      "contextTimeoutMs": {
        "type": "integer",
        "description": "Max milliseconds to wait for follow-up messages before finalizing a skill execution record",
        "minimum": 0,
        "default": 60000
      },
      "router": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "targets": {
            "type": "object",
            "properties": {
              "subagent": {
                "type": "boolean",
                "default": true
              },
              "cron": {
                "type": "boolean",
                "default": true
              }
            },
            "default": {
              "subagent": true,
              "cron": true
            }
          },
          "maxSkillsToNudge": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "minScore": {
            "type": "number",
            "default": 6
          },
          "recencyWindow": {
            "type": "integer",
            "minimum": 1,
            "default": 10,
            "description": "Skip nudging a skill if it was nudged within this many messages"
          },
          "overrides": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "taskPattern": {
                  "type": "string"
                },
                "skills": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["taskPattern", "skills"]
            },
            "default": []
          },
          "skillKeywords": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "default": {}
          },
          "blocklist": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "default": {
          "enabled": true
        }
      }
    }
  }
}
